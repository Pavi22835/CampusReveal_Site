generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String       @id @default(cuid())
  name           String
  email          String?      @unique
  password       String?
  role           String       @default("STUDENT")
  avatar         String?
  bio            String?
  universityId   String?      @map("university_id")
  graduationYear Int?         @map("graduation_year")
  major          String?
  credits        Int          @default(0)
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  isGuest        Boolean      @default(false)
  isVerified     Boolean      @default(false)
  lastLogin      DateTime?
  phone          String?      @unique
  
  // SOFT DELETE / TRASH FIELDS
  isTrashed      Boolean      @default(false) @map("is_trashed")
  trashedAt      DateTime?    @map("trashed_at")
  
  comments       Comment[]
  discussions    Discussion[]
  mentor         Mentor?
  reviews        Review[]
  university     University?  @relation(fields: [universityId], references: [id])

  @@index([email])
  @@index([role])
  @@index([phone])
  @@index([isTrashed])
  @@map("users")
}

model University {
  id              String    @id @default(cuid())
  name            String    @unique
  location        String
  city            String?
  state           String?
  rating          Float     @default(0)
  followers       Int       @default(0)
  walkScore       Int?      @map("walk_score")
  walkDescription String?   @map("walk_description")
  transit         String?
  transitDetail   String?   @map("transit_detail")
  acceptanceRate  String?   @map("acceptance_rate")
  medianSalary    String?   @map("median_salary")
  financialAid    String?   @map("financial_aid")
  studentCount    Int?      @map("student_count")
  description     String?
  images          String[]  @default([])
  ratings         Json      @default("{}")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  accreditation   String?
  affiliation     String?
  category        String?   @map("category")
  clubs           String[]  @default([])
  courses         String?
  email           String?
  established     String?   @map("established")
  facilities      String[]  @default([])
  facultyCount    Int?      @map("faculty_count")
  googleMapsLink  String?   @map("google_maps_link")
  hostelFee       String?   @map("hostel_fee")
  instagram       String?
  intake          String?
  isActive        Boolean   @default(true) @map("is_active")
  isFeatured      Boolean   @default(false) @map("is_featured")
  linkedin        String?
  mission         String?
  phone           String?
  pincode         String?
  placementRate   String?   @map("placement_rate")
  shortName       String?   @map("short_name")
  sports          String[]  @default([])
  tuitionFee      String?   @map("tuition_fee")
  twitter         String?
  type            String?   @map("type")
  vision          String?
  website         String?
  imageUrl        String?   @map("image_url")
  logoUrl         String?   @map("logo_url")  // College logo URL for display in cards
  
  // SOFT DELETE / TRASH FIELDS
  isTrashed       Boolean   @default(false) @map("is_trashed")
  trashedAt       DateTime? @map("trashed_at")
  
  // ==================== COLLEGE SEARCH & FILTER FIELDS ====================
  
  // ACADEMIC STREAM - Engineering, Arts, Commerce, Science, Law, Management, Medical
  academicStream  String?   @map("academic_stream")
  
  // ACADEMIC LEVEL - UG, PG, Diploma, PhD, Certificate, Integrated
  academicLevel   String?   @map("academic_level")
  
  // DEPARTMENT - Computer Science, Mechanical, Civil, Electronics, Business, Economics
  department      String?   @map("department")
  
  // COURSES OFFERED - Array of courses (B.Tech, BBA, MBA, B.Sc, B.Com, etc.)
  offeredCourses  String[]  @default([]) @map("offered_courses")

  // TRANSPORT SCORE - 0-100 for transit connectivity
  transportScore  Int?      @default(0) @map("transport_score")
  
  // ENTRANCE EXAM REQUIRED - JEE, CAT, NEET, GATE, etc.
  entranceExam    String?   @map("entrance_exam")
  
  // SCHOLARSHIP AVAILABLE
  scholarship     Boolean?  @default(false) @map("scholarship")
  
  // HOSTEL AVAILABILITY
  hostelAvailable Boolean?  @default(false) @map("hostel_available")
  
  // GENDER - Co-ed, Women Only, Men Only
  genderType      String?   @default("CO_ED") @map("gender_type")
  
  // RELIGIOUS AFFILIATION
  religiousAffiliation String? @map("religious_affiliation")
  
  // CAMPUS AREA (in acres)
  campusArea      Int?      @map("campus_area")
  
  // LIBRARY RESOURCES
  libraryBooks    Int?      @map("library_books")
  
  // SPORTS FACILITIES RATING (0-5)
  sportsRating    Float?    @default(0) @map("sports_rating")
  
  // PLACEMENT PERCENTAGE
  placementPercent Float?   @default(0) @map("placement_percent")
  
  // HIGHEST PACKAGE
  highestPackage  String?   @map("highest_package")
  
  // AVERAGE PACKAGE
  averagePackage  String?   @map("average_package")
  
  reviews         Review[]
  users           User[]
  
  // Many-to-many relation with courses
  universityCourses UniversityCourse[]

  @@index([name])
  @@index([city])
  @@index([state])
  @@index([rating])
  @@index([isFeatured])
  @@index([isTrashed])
  @@index([academicStream])
  @@index([academicLevel])
  @@index([department])
  @@index([transportScore])
  @@index([placementPercent])
  @@map("universities")
}

// Course model for proper relationship
model Course {
  id          String   @id @default(cuid())
  name        String   @unique // B.Tech Computer Science, BBA, etc.
  code        String?  // CS101, BBA101, etc.
  level       String?  // UG, PG, Diploma, PhD
  stream      String?  // Engineering, Arts, Commerce
  department  String?  // Computer Science, Mechanical, etc.
  duration    Int?     // in years
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  
  // Many-to-many relation with universities
  universityCourses UniversityCourse[]

  @@index([name])
  @@index([level])
  @@index([stream])
  @@index([department])
  @@map("courses")
}

// Many-to-many relation between University and Course
model UniversityCourse {
  universityId String
  courseId     String
  university   University @relation(fields: [universityId], references: [id], onDelete: Cascade)
  course       Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  
  @@id([universityId, courseId])
  @@map("university_courses")
}

// Department model
model Department {
  id          String   @id @default(cuid())
  name        String   @unique // Computer Science, Mechanical Engineering, etc.
  code        String?  // CS, ME, etc.
  stream      String?  // Engineering, Arts
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  
  @@index([name])
  @@index([stream])
  @@map("departments")
}

model Review {
  id           String     @id @default(cuid())
  title        String
  content      String
  rating       Float      @default(0)
  ratings      Json       @default("{}")
  pros         String[]   @default([])
  cons         String[]   @default([])
  tips         String?
  classYear    String?    @map("class_year")
  major        String?
  helpful      Int        @default(0)
  userId       String     @map("user_id")
  universityId String     @map("university_id")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  projectLink  String?    @map("project_link")
  verified     Boolean    @default(false)
  
  // SOFT DELETE / TRASH FIELDS
  isTrashed    Boolean    @default(false) @map("is_trashed")
  trashedAt    DateTime?  @map("trashed_at")
  
  university   University @relation(fields: [universityId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([universityId])
  @@index([rating])
  @@index([createdAt])
  @@index([isTrashed])
  @@map("reviews")
}

model Discussion {
  id        String    @id @default(cuid())
  title     String
  content   String
  tags      String[]  @default([])
  replies   Int       @default(0)
  views     Int       @default(0)
  likes     Int       @default(0)
  authorId  String    @map("author_id")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  comments  Comment[]
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  
  // SOFT DELETE / TRASH FIELDS
  isTrashed Boolean   @default(false) @map("is_trashed")
  trashedAt DateTime? @map("trashed_at")

  @@index([authorId])
  @@index([createdAt])
  @@index([isTrashed])
  @@map("discussions")
}

model Comment {
  id           String     @id @default(cuid())
  content      String
  likes        Int        @default(0)
  authorId     String     @map("author_id")
  discussionId String     @map("discussion_id")
  createdAt    DateTime   @default(now()) @map("created_at")
  author       User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  discussion   Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  
  // SOFT DELETE / TRASH FIELDS
  isTrashed    Boolean    @default(false) @map("is_trashed")
  trashedAt    DateTime?  @map("trashed_at")

  @@index([authorId])
  @@index([discussionId])
  @@index([isTrashed])
  @@map("comments")
}

model Mentor {
  id           String   @id @default(cuid())
  userId       String   @unique @map("user_id")
  expertise    String[] @default([])
  availability Boolean  @default(true)
  bio          String?
  sessions     Int      @default(0)
  rating       Float    @default(0)
  createdAt    DateTime @default(now()) @map("created_at")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // SOFT DELETE / TRASH FIELDS
  isTrashed    Boolean  @default(false) @map("is_trashed")
  trashedAt    DateTime? @map("trashed_at")

  @@index([userId])
  @@index([availability])
  @@index([isTrashed])
  @@map("mentors")
}

model OTP {
  id        String   @id @default(cuid())
  phone     String
  otp       String
  purpose   String   @default("login")
  isUsed    Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([phone])
  @@index([expiresAt])
  @@index([isUsed])
  @@map("otps")
}