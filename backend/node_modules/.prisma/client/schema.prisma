generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String    @id @default(cuid())
  name           String
  email          String?   @unique
  password       String?
  role           String    @default("STUDENT")
  avatar         String?
  bio            String?
  universityId   String?   @map("university_id")
  graduationYear Int?      @map("graduation_year")
  major          String?
  credits        Int       @default(0)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  isGuest        Boolean   @default(false)
  isVerified     Boolean   @default(false)
  lastLogin      DateTime?
  phone          String?   @unique

  isTrashed Boolean   @default(false) @map("is_trashed")
  trashedAt DateTime? @map("trashed_at")

  comments    Comment[]
  discussions Discussion[]
  mentor      Mentor?
  reviews     Review[]
  university  University?  @relation(fields: [universityId], references: [id])

  // ✅ ADDED: Like relations
  discussionLikes DiscussionLike[]
  commentLikes    CommentLike[]

  @@index([email])
  @@index([role])
  @@index([phone])
  @@index([isTrashed])
  @@map("users")
}

model University {
  id String @id @default(cuid())

  // 1. Basic Information
  name        String  @unique
  shortName   String? @map("short_name")
  established String?
  type        String?
  category    String?
  naacGrade   String? @map("naac_grade")

  // 2. Branding & Media
  logoUrl        String?  @map("logo_url")
  campusVideoUrl String?  @map("campus_video_url")
  images         String[] @default([])

  // 3. Academic Information
  academicStreams String[] @default([]) @map("academic_streams")
  academicLevels  String[] @default([]) @map("academic_levels")
  departments     String[] @default([])
  offeredCourses  String[] @default([]) @map("offered_courses")
  specializations String?
  affiliation     String?
  approvedBy      String?  @map("approved_by")
  mission         String?
  vision          String?

  // 4. Facilities & Campus
  hostelAvailable    Boolean  @default(false) @map("hostel_available")
  hostelType         String?  @map("hostel_type")
  transportAvailable Boolean  @default(false) @map("transport_available")
  campusFacilities   String[] @default([]) @map("campus_facilities")

  // 5. Location Information
  country        String? @default("India")
  state          String?
  city           String?
  pincode        String?
  location       String?
  googleMapsLink String? @map("google_maps_link")

  // 6. Placement & Statistics
  rating         Float   @default(0)
  studentCount   Int?    @map("student_count")
  facultyCount   Int?    @map("faculty_count")
  placementRate  String? @map("placement_rate")
  highestPackage String? @map("highest_package")
  averagePackage String? @map("average_package")
  topRecruiters  String? @map("top_recruiters")

  // 7. Fees Structure
  tuitionFee           String? @map("tuition_fee")
  hostelFee            String? @map("hostel_fee")
  scholarshipAvailable Boolean @default(false) @map("scholarship_available")

  // 8. Contact & Social Links
  website   String?
  phone     String?
  email     String?
  instagram String?
  linkedin  String?
  facebook  String?
  youtube   String?

  // 9. Description & SEO
  description String?
  keywords    String?

  // Legacy fields
  followers  Int      @default(0)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  isActive   Boolean  @default(true) @map("is_active")
  isFeatured Boolean  @default(false) @map("is_featured")
  imageUrl   String?  @map("image_url")

  // Soft delete
  isTrashed Boolean   @default(false) @map("is_trashed")
  trashedAt DateTime? @map("trashed_at")

  // Relations
  reviews           Review[]
  users             User[]
  universityCourses UniversityCourse[]

  @@index([name])
  @@index([city])
  @@index([state])
  @@index([rating])
  @@index([isFeatured])
  @@index([isTrashed])
  @@map("universities")
}

model Course {
  id          String   @id @default(cuid())
  name        String   @unique
  code        String?
  level       String?
  stream      String?
  department  String?
  duration    Int?
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  universityCourses UniversityCourse[]

  @@index([name])
  @@index([level])
  @@index([stream])
  @@map("courses")
}

model UniversityCourse {
  universityId String
  courseId     String
  university   University @relation(fields: [universityId], references: [id], onDelete: Cascade)
  course       Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@id([universityId, courseId])
  @@map("university_courses")
}

model Department {
  id          String   @id @default(cuid())
  name        String   @unique
  code        String?
  stream      String?
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([name])
  @@index([stream])
  @@map("departments")
}

model Review {
  id           String   @id @default(cuid())
  title        String
  content      String
  rating       Float    @default(0)
  ratings      Json     @default("{}")
  pros         String[] @default([])
  cons         String[] @default([])
  tips         String?
  classYear    String?  @map("class_year")
  major        String?
  helpful      Int      @default(0)
  userId       String   @map("user_id")
  universityId String   @map("university_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  projectLink  String?  @map("project_link")
  verified     Boolean  @default(false)

  isTrashed Boolean   @default(false) @map("is_trashed")
  trashedAt DateTime? @map("trashed_at")

  university University @relation(fields: [universityId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([universityId])
  @@index([rating])
  @@index([createdAt])
  @@index([isTrashed])
  @@map("reviews")
}

model Discussion {
  id        String    @id @default(cuid())
  title     String
  content   String
  tags      String[]  @default([])
  replies   Int       @default(0)
  views     Int       @default(0)
  likes     Int       @default(0)
  authorId  String    @map("author_id")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  comments  Comment[]
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)

  isTrashed Boolean   @default(false) @map("is_trashed")
  trashedAt DateTime? @map("trashed_at")

  // ✅ ADDED: Like relation
  likesRelation DiscussionLike[]

  @@index([authorId])
  @@index([createdAt])
  @@index([isTrashed])
  @@map("discussions")
}

// ✅ ADDED: DiscussionLike model
model DiscussionLike {
  id           String     @id @default(cuid())
  discussionId String     @map("discussion_id")
  userId       String     @map("user_id")
  discussion   Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now()) @map("created_at")

  @@unique([discussionId, userId])
  @@index([discussionId])
  @@index([userId])
  @@map("discussion_likes")
}

model Comment {
  id           String     @id @default(cuid())
  content      String
  likes        Int        @default(0)
  authorId     String     @map("author_id")
  discussionId String     @map("discussion_id")
  createdAt    DateTime   @default(now()) @map("created_at")
  author       User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  discussion   Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)

  isTrashed Boolean   @default(false) @map("is_trashed")
  trashedAt DateTime? @map("trashed_at")

  // ✅ ADDED: Like relation
  likesRelation CommentLike[]

  @@index([authorId])
  @@index([discussionId])
  @@index([isTrashed])
  @@map("comments")
}

// ✅ ADDED: CommentLike model
model CommentLike {
  id        String   @id @default(cuid())
  commentId String   @map("comment_id")
  userId    String   @map("user_id")
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([commentId, userId])
  @@index([commentId])
  @@index([userId])
  @@map("comment_likes")
}

model Mentor {
  id           String   @id @default(cuid())
  userId       String   @unique @map("user_id")
  expertise    String[] @default([])
  availability Boolean  @default(true)
  bio          String?
  sessions     Int      @default(0)
  rating       Float    @default(0)
  createdAt    DateTime @default(now()) @map("created_at")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  isTrashed Boolean   @default(false) @map("is_trashed")
  trashedAt DateTime? @map("trashed_at")

  @@index([userId])
  @@index([availability])
  @@index([isTrashed])
  @@map("mentors")
}

model OTP {
  id        String   @id @default(cuid())
  phone     String
  otp       String
  purpose   String   @default("login")
  isUsed    Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([phone])
  @@index([expiresAt])
  @@index([isUsed])
  @@map("otps")
}
